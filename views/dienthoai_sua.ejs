<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .form-card { border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
        .form-label { font-weight: 600; color: #444; font-size: 0.9rem; }
        .form-control { border-radius: 10px; padding: 12px; border: 1px solid #eee; background-color: #fafafa; }
        .btn-update { border-radius: 50px; padding: 12px 60px; font-weight: bold; background: #0d6efd; color: #fff; border: none; }
        .current-img-box { width: 120px; height: 120px; object-fit: contain; border: 1px dashed #ccc; padding: 5px; border-radius: 12px; background: #fff; }
    </style>
</head>
<body>
    <%- include('navbar') %>

    <div class="container py-5">
        <div class="card form-card mx-auto bg-white" style="max-width: 900px;">
            <div class="card-body p-5">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <h4 class="fw-bold text-primary m-0">
                        <i class="bi bi-pencil-square me-2"></i>Sửa thông tin sản phẩm
                    </h4>
                    <a href="/dienthoai" class="btn btn-light rounded-pill border px-4 py-2 small fw-bold">Hủy & Quay lại</a>
                </div>

                <form action="/dienthoai/sua/<%= dt._id %>" method="post" enctype="multipart/form-data">
                    <div class="row g-4">
                        <div class="col-md-8">
                            <label class="form-label">Tên máy chính thức *</label>
                            <input type="text" class="form-control" name="TenSP" value="<%= dt.TenSP %>" required>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Thương hiệu</label>
                            <select class="form-select form-control" name="ThuongHieu">
                                <% thuonghieu.forEach(th => { %>
                                    <option value="<%= th._id %>" <%= (dt.ThuongHieu && dt.ThuongHieu.toString() == th._id.toString()) ? 'selected' : '' %>>
                                        <%= th.TenThuongHieu %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Giá bán (VNĐ) *</label>
                            <input type="number" class="form-control" name="DonGia" value="<%= dt.DonGia %>" required>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Số lượng trong kho *</label>
                            <input type="number" class="form-control" name="SoLuong" value="<%= dt.SoLuong %>" required>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Thay đổi hình ảnh mới</label>
                            <input type="file" class="form-control" name="HinhAnh">
                        </div>

                        <div class="col-12 mt-2">
                            <div class="d-flex align-items-center gap-3 bg-light p-3 rounded-4 border border-white">
                                <img src="<%= dt.HinhAnh %>" class="current-img-box shadow-sm">
                                <div>
                                    <p class="m-0 fw-bold text-dark small">Hình ảnh hiện tại</p>
                                    <p class="m-0 text-muted small italic">Nếu không muốn đổi ảnh, hãy để trống ô chọn file ở trên.</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12"><hr class="opacity-50"></div>

                        <div class="col-md-6">
                            <label class="form-label">Màn hình</label>
                            <input type="text" class="form-control" name="ManHinh" value="<%= dt.ManHinh %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">CPU</label>
                            <input type="text" class="form-control" name="CPU" value="<%= dt.CPU %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">RAM</label>
                            <input type="text" class="form-control" name="Ram" value="<%= dt.Ram %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">ROM</label>
                            <input type="text" class="form-control" name="Rom" value="<%= dt.Rom %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Pin</label>
                            <input type="text" class="form-control" name="Pin" value="<%= dt.Pin %>">
                        </div>
                    </div>

                    <div class="text-center mt-5">
                        <button type="submit" class="btn btn-update shadow-sm rounded-pill px-5 py-2">
                            <i class="bi bi-cloud-arrow-up-fill me-2"></i>CẬP NHẬT LƯU THAY ĐỔI
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <%- include('footer') %>
    </div>
    <%- include('javascript') %>
</body>
</html>