<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }
        .form-card { border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
        .form-label { font-weight: 600; color: #444; font-size: 0.9rem; }
        .form-control { border-radius: 10px; padding: 12px; border: 1px solid #eee; background-color: #fafafa; }
        .btn-update { border-radius: 50px; padding: 12px 60px; font-weight: bold; background: #0d6efd; color: #fff; border: none; }
    </style>
</head>
<body>
    <%- include('navbar') %>
    <div class="container py-5">
        <div class="card form-card mx-auto bg-white" style="max-width: 700px;">
            <div class="card-body p-5">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <h4 class="fw-bold text-primary m-0"><i class="bi bi-pencil-square me-2"></i>Sửa thương hiệu</h4>
                    <a href="/thuonghieu" class="btn btn-light rounded-pill border px-4 py-2 small fw-bold">Hủy & Quay lại</a>
                </div>

                <form action="/thuonghieu/sua/<%= thuonghieu._id %>" method="post" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label class="form-label">Tên hãng</label>
                        <input type="text" class="form-control" name="TenThuongHieu" value="<%= thuonghieu.TenThuongHieu %>" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Thay đổi Logo (bỏ qua nếu giữ ảnh cũ)</label>
                        <input type="file" class="form-control" name="HinhAnh" accept="image/*">
                        <% if(thuonghieu.HinhAnh) { %>
                            <div class="mt-2 text-muted small italic">Ảnh hiện tại:</div>
                            <img src="<%= thuonghieu.HinhAnh %>" height="60" class="border rounded p-1 bg-white shadow-sm mt-1">
                        <% } %>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Mô tả</label>
                        <textarea class="form-control" name="MoTa" rows="3"><%= thuonghieu.MoTa %></textarea>
                    </div>

                    <div class="text-center mt-5">
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">CẬP NHẬT</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>