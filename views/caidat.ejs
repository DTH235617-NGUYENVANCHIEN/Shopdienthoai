<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>Cài đặt tài khoản - <%= session.HoVaTen %></title>
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }
        .profile-card { border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); background: #fff; }
        .user-avatar { width: 120px; height: 120px; object-fit: cover; border: 5px solid #fff; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        .nav-pills .nav-link { border-radius: 10px; color: #666; font-weight: 600; padding: 12px 20px; transition: 0.3s; }
        .nav-pills .nav-link.active { background-color: #0d6efd; color: #fff; box-shadow: 0 4px 12px rgba(13, 110, 253, 0.3); }
        .nav-pills .nav-link:hover:not(.active) { background-color: #e9ecef; }
    </style>
</head>
<body>
    <%- include('navbar') %>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                
                <% if (typeof message !== 'undefined' && message) { %>
                    <div class="alert <%= message.includes('thành công') ? 'alert-success' : 'alert-danger' %> alert-dismissible fade show shadow-sm mb-4">
                        <i class="bi bi-info-circle me-2"></i><%= message %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="card profile-card p-3">
                            <div class="text-center mb-4 pt-3">
                                <% if(taikhoan.HinhAnh) { %>
                                    <img src="<%= taikhoan.HinhAnh %>" class="rounded-circle user-avatar mb-3">
                                <% } else { %>
                                    <i class="bi bi-person-circle text-secondary" style="font-size: 80px;"></i>
                                <% } %>
                                <h5 class="fw-bold mb-0"><%= taikhoan.HoVaTen %></h5>
                                <p class="text-muted small"><%= taikhoan.TenDangNhap %></p>
                            </div>
                            
                            <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist">
                                <button class="nav-link active text-start mb-2" id="v-pills-profile-tab" data-bs-toggle="pill" data-bs-target="#v-pills-profile" type="button" role="tab">
                                    <i class="bi bi-person-vcard me-2"></i>Hồ sơ cá nhân
                                </button>
                                <button class="nav-link text-start" id="v-pills-password-tab" data-bs-toggle="pill" data-bs-target="#v-pills-password" type="button" role="tab">
                                    <i class="bi bi-shield-lock me-2"></i>Đổi mật khẩu
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-8">
                        <div class="tab-content" id="v-pills-tabContent">
                            
                            <div class="tab-pane fade show active" id="v-pills-profile" role="tabpanel">
                                <div class="card profile-card p-4">
                                    <h5 class="fw-bold mb-4">Thông tin tài khoản</h5>
                                    <form action="/caidat/capnhat" method="post" enctype="multipart/form-data">
                                        <div class="mb-4">
                                            <label class="form-label small fw-bold text-muted text-uppercase">Ảnh đại diện</label>
                                            <div class="d-flex align-items-center">
                                                <input type="file" class="form-control form-control-sm w-auto" name="HinhAnh" accept="image/*">
                                                <span class="ms-3 text-muted small">Dùng ảnh chân dung để mọi người nhận ra bạn.</span>
                                            </div>
                                        </div>
                                        <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold">Họ và tên</label>
                                            <input type="text" class="form-control" name="HoVaTen" value="<%= taikhoan.HoVaTen %>" required>
                                        </div>
                                        
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold">Tên đăng nhập</label>
                                            <input type="text" class="form-control bg-light" value="<%= taikhoan.TenDangNhap %>" disabled>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold">Số điện thoại</label>
                                            <input type="text" class="form-control" name="DienThoai" value="<%= taikhoan.DienThoai || '' %>" placeholder="Chưa cập nhật">
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold">Email</label>
                                            <input type="email" class="form-control" name="Email" value="<%= taikhoan.Email %>" required placeholder="Nhập email của bạn">
                                        </div>
                                        
                                        <div class="col-12">
                                            <label class="form-label small fw-bold">Địa chỉ giao hàng mặc định</label>
                                            <textarea class="form-control" name="DiaChi" rows="2" placeholder="Nhập địa chỉ chi tiết của bạn..."><%= taikhoan.DiaChi || '' %></textarea>
                                        </div>
                                    </div>
                                        <button type="submit" class="btn btn-primary fw-bold px-4 py-2 mt-4 shadow-sm">LƯU THAY ĐỔI</button>
                                    </form>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="v-pills-password" role="tabpanel">
                                <div class="card profile-card p-4">
                                    <h5 class="fw-bold mb-4">Thay đổi mật khẩu</h5>
                                    <form action="/caidat/doimatkhau" method="post">
                                        <div class="mb-3">
                                            <label class="form-label small fw-bold">Mật khẩu hiện tại</label>
                                            <input type="password" class="form-control" name="MatKhauCu" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label small fw-bold">Mật khẩu mới</label>
                                            <input type="password" class="form-control" name="MatKhauMoi" required>
                                        </div>
                                        <div class="mb-4">
                                            <label class="form-label small fw-bold">Xác nhận mật khẩu mới</label>
                                            <input type="password" class="form-control" name="XacNhanMatKhau" required>
                                        </div>
                                        <button type="submit" class="btn btn-outline-danger fw-bold px-4 py-2 shadow-sm">CẬP NHẬT MẬT KHẨU</button>
                                    </form>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('javascript') %>
    
</body>
</html>