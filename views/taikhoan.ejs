<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }
        .dashboard-card { border: none; border-radius: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
        .avatar-img { width: 45px; height: 45px; object-fit: cover; border-radius: 50%; border: 2px solid #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
    </style>
</head>
<body>
    <%- include('navbar') %>

    <div class="container py-5 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold m-0"><i class="bi bi-people-fill text-warning me-2"></i>Quản Lý Người Dùng</h3>
            <div>
                <a href="/taikhoan/them" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
                    <i class="bi bi-person-plus-fill me-1"></i> Thêm Tài Khoản
                </a>
                <a href="/admin" class="btn btn-light border rounded-pill btn-sm px-3 ms-2">Quay lại</a>
            </div>
        </div>

        <% if (typeof session !== 'undefined' && session.success) { %>
            <div class="alert alert-success shadow-sm rounded-3"><%- session.success %></div>
            <% delete session.success; %>
        <% } %>
        <% if (typeof session !== 'undefined' && session.error) { %>
            <div class="alert alert-danger shadow-sm rounded-3"><%- session.error %></div>
            <% delete session.error; %>
        <% } %>

        <div class="card dashboard-card">
            <div class="card-body p-0 table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3">Tài khoản</th>
                            <th class="py-3">Họ và Tên</th>
                            <th class="py-3">Email</th>
                            <th class="text-center py-3">Phân quyền</th>
                            <th class="text-center py-3">Trạng thái</th>
                            <th class="text-center py-3" style="width: 180px;">Thiết lập</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% taikhoan.forEach(tk => { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <% if(tk.HinhAnh) { %>
                                            <img src="<%= tk.HinhAnh %>" class="avatar-img me-3" alt="avatar">
                                        <% } else { %>
                                            <i class="bi bi-person-circle fs-2 text-secondary me-3"></i>
                                        <% } %>
                                        <span class="fw-bold text-dark"><%= tk.TenDangNhap %></span>
                                    </div>
                                </td>
                                <td><span class="text-secondary fw-semibold"><%= tk.HoVaTen %></span></td>
                                <td><span class="text-muted small"><%= tk.Email || 'Chưa cập nhật' %></span></td>
                                <td class="text-center">
                                    <% if(tk.QuyenHan == 1) { %>
                                        <span class="badge bg-danger rounded-pill px-3">Admin</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary rounded-pill px-3">Khách</span>
                                    <% } %>
                                </td>
                                <td class="text-center">
                                   

                                    <   % if(typeof session !== 'undefined' && session.MaNguoiDung != tk._id.toString()) { %>
                                        <% if(tk.KichHoat == 1) { %>
                                            <a href="/taikhoan/khoa/<%= tk._id %>" class="btn btn-sm btn-outline-warning px-2 me-1" title="Khóa nick này">
                                                <i class="bi bi-lock-fill"></i>
                                            </a>
                                        <% } else { %>
                                            <a href="/taikhoan/khoa/<%= tk._id %>" class="btn btn-sm btn-outline-success px-2 me-1" title="Mở khóa nick này">
                                                <i class="bi bi-unlock-fill"></i>
                                            </a>
                                        <% } %>
                                    <% } else { %>
                                        <button class="btn btn-sm btn-outline-secondary px-2 me-1 disabled"><i class="bi bi-lock-fill"></i></button>
                                    <% } %>
                                    
                                </td>
                                <td class="text-center">
                                    <a href="/taikhoan/sua/<%= tk._id %>" class="btn btn-sm btn-outline-primary px-3 me-1">
                                        <i class="bi bi-gear"></i> Sửa
                                    </a>
                                    <% if(typeof session !== 'undefined' && session.MaNguoiDung != tk._id.toString()) { %>
                                        <a href="/taikhoan/xoa/<%= tk._id %>" class="btn btn-sm btn-outline-danger px-2" onclick="return confirm('Xóa vĩnh viễn tài khoản này?');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    <% } else { %>
                                        <button class="btn btn-sm btn-outline-secondary px-2 disabled"><i class="bi bi-trash"></i></button>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
        <%- include('footer') %>
    <%- include('javascript') %>
</body>
</html>	