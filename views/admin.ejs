<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }
        .dashboard-card { border: none; border-radius: 20px; transition: 0.3s; padding: 30px 20px; text-align: center; display: block; text-decoration: none; color: #212529; background: #fff; }
        .dashboard-card:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); }
        .icon-circle { width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px auto; font-size: 2.5rem; }
    </style>
</head>
<body>
    <%- include('navbar') %>

    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Bảng Điều Khiển Quản Trị</h2>
            <p class="text-muted">Chọn một chức năng để bắt đầu quản lý</p>
        </div>
        <div class="row g-4 mb-5">
            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="mb-1 fw-bold opacity-75">TỔNG DOANH THU</p>
                                <h3 class="mb-0 fw-bold"><%= tongDoanhThu.toLocaleString('vi-VN') %> đ</h3>
                            </div>
                            <div class="bg-white bg-opacity-25 rounded-circle p-3">
                                <i class="bi bi-wallet2 fs-2"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4" style="background: linear-gradient(135deg, #dc3545 0%, #f87171 100%); color: white;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="mb-1 fw-bold opacity-75">ĐƠN CHỜ DUYỆT</p>
                                <h3 class="mb-0 fw-bold"><%= donHangMoi %> <span class="fs-6 fw-normal">đơn</span></h3>
                            </div>
                            <div class="bg-white bg-opacity-25 rounded-circle p-3">
                                <i class="bi bi-bag-plus-fill fs-2"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4" style="background: linear-gradient(135deg, #0d6efd 0%, #4facfe 100%); color: white;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="mb-1 fw-bold opacity-75">KHO HÀNG</p>
                                <h3 class="mb-0 fw-bold"><%= tongSanPham %> <span class="fs-6 fw-normal">sản phẩm</span></h3>
                            </div>
                            <div class="bg-white bg-opacity-25 rounded-circle p-3">
                                <i class="bi bi-box-seam fs-2"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4" style="background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%); color: white;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="mb-1 fw-bold opacity-75">KHÁCH HÀNG</p>
                                <h3 class="mb-0 fw-bold"><%= tongKhachHang %> <span class="fs-6 fw-normal">người</span></h3>
                            </div>
                            <div class="bg-white bg-opacity-25 rounded-circle p-3">
                                <i class="bi bi-people-fill fs-2"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        <div class="row g-4 justify-content-center">
            
            <div class="col-sm-6 col-md-4 col-lg-3">
                <a href="/dienthoai" class="card dashboard-card shadow-sm">
                    <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-phone-fill"></i>
                    </div>
                    <h5 class="fw-bold">Sản Phẩm</h5>
                    <p class="text-muted small mb-0">Thêm, sửa, xóa kho hàng</p>
                </a>
            </div>

            <div class="col-sm-6 col-md-4 col-lg-3">
                <a href="/thuonghieu" class="card dashboard-card shadow-sm">
                    <div class="icon-circle bg-danger bg-opacity-10 text-danger">
                        <i class="bi bi-tags-fill"></i>
                    </div>
                    <h5 class="fw-bold">Thương Hiệu</h5>
                    <p class="text-muted small mb-0">Quản lý các hãng</p>
                </a>
            </div>

            <div class="col-sm-6 col-md-4 col-lg-3">
                <a href="/donhang" class="card dashboard-card shadow-sm">
                    <div class="icon-circle bg-success bg-opacity-10 text-success">
                        <i class="bi bi-cart-check-fill"></i>
                    </div>
                    <h5 class="fw-bold">Đơn Hàng</h5>
                    <p class="text-muted small mb-0">Duyệt và xử lý đơn</p>
                </a>
            </div>

            <div class="col-sm-6 col-md-4 col-lg-3">
                <a href="/taikhoan" class="card dashboard-card shadow-sm">
                    <div class="icon-circle bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <h5 class="fw-bold">Người Dùng</h5>
                    <p class="text-muted small mb-0">Danh sách người dùng</p>
                </a>
            </div>

        </div>
    </div>

    <%- include('javascript') %>
</body>
</html>