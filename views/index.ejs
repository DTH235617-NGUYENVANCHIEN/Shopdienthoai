<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    

    <title><%= title %></title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; }
        
        .product-card { 
            border: none; 
            border-radius: 15px; 
            background-color: #ffffff; 
            transition: all 0.3s ease; 
            overflow: hidden;
            height: 100%;
        }
        .product-card:hover { 
            transform: translateY(-5px); 
            box-shadow: 0 10px 20px rgba(0,0,0,0.1); 
        }
        .card-img-container {
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background-color: #fcfcfc;
        }
        .card-img-top { 
            max-height: 100%; 
            max-width: 100%; 
            object-fit: contain; 
        }
        .card-body { padding: 1.25rem; }
        .product-title { font-size: 1.1rem; font-weight: 600; color: #212529; margin-bottom: 0.5rem; }
        .product-title a:hover { color: #0d6efd !important; }
        .product-price { font-size: 1.2rem; font-weight: 700; color: #dc3545; }
        .btn-add-cart { border-radius: 20px; font-weight: 600; padding: 5px 15px; }
        
        /* Tiêu đề mục nhãn hàng */
        .brand-section-title {
            border-left: 5px solid #0d6efd;
            padding-left: 15px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
    </style>
</head>
<body>
    
    <%- include('navbar') %>

    <div class="bg-dark text-white py-5 mb-5 shadow-sm">
        <div class="container text-center">
            <h1 class="display-5 fw-bold">Khám Phá Công Nghệ Mới</h1>
            <p class="lead opacity-75">Những mẫu smartphone hàng đầu, giá tốt nhất tại ShopDienThoai.</p>
        </div>
    </div>

    <div class="container pb-5">
        
        <% data.forEach(hang => { %>
            <div class="brand-section mb-5">
                <div class="brand-section-title">
                    <h3 class="fw-bold m-0 text-uppercase"><%= hang.tenHang %></h3>
                    <a href="/thuonghieu/<%= hang.idHang %>" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                        Xem thêm hãng <%= hang.tenHang %> <i class="bi bi-arrow-right-short"></i>
                    </a>
                </div>

                <div class="row g-4">
                    <% hang.danhSachSP.forEach(dt => { %>
                        <div class="col-6 col-md-4 col-lg-3">
                            <div class="card product-card shadow-sm">
                                <div class="card-img-container">
                                    <a href="/dienthoai/chitiet/<%= dt._id %>" class="d-flex align-items-center justify-content-center w-100 h-100 text-decoration-none">
                                        <% if(dt.HinhAnh) { %>
                                            <img src="<%= dt.HinhAnh.replace('/img/', '/images/') %>" class="card-img-top" alt="<%= dt.TenSP %>">
                                        <% } else { %>
                                            <i class="bi bi-phone text-muted display-1"></i>
                                        <% } %>
                                    </a>
                                </div>
                                <div class="card-body d-flex flex-column">
                                    <h5 class="product-title text-truncate">
                                        <a href="/dienthoai/chitiet/<%= dt._id %>" class="text-dark text-decoration-none">
                                            <%= dt.TenSP %>
                                        </a>
                                    </h5>
                                    
                                    <div class="mt-auto d-flex justify-content-between align-items-center">
                                        <span class="product-price"><%= dt.DonGia.toLocaleString('vi-VN') %>đ</span>
                                       <a href="javascript:void(0)" 
                                        onclick="themVaoGioHang('<%= dt._id %>')" 
                                        class="btn btn-outline-primary rounded-circle">
                                            <i class="bi bi-cart"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
            <% }); %>

    </div>

    <%- include('footer') %>
    <%- include('javascript') %>
</body>
</html>