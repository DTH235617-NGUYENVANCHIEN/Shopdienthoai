<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
</head>
<body class="bg-light">
    <%- include('navbar') %>
    <div class="container mt-4">
        <h3 class="fw-bold mb-4"><i class="bi bi-bag-heart text-danger me-2"></i>Đơn hàng của tôi</h3>
        
        <% if(donhang.length == 0) { %>
            <div class="text-center py-5 bg-white rounded-4 shadow-sm">
                <i class="bi bi-cart-x fs-1 text-muted"></i>
                <p class="mt-3 text-muted">Bạn chưa có đơn hàng nào.</p>
                <a href="/dienthoai/list" class="btn btn-warning rounded-pill fw-bold">Mua sắm ngay</a>
            </div>
        <% } else { %>
            <div class="row g-3">
                <% donhang.forEach(dh => { %>
                    <div class="col-12">
                        <div class="card border-0 shadow-sm rounded-4 p-3 bg-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="small text-muted">Mã đơn: <span class="fw-bold text-dark"><%= dh._id.toString().substring(0,8).toUpperCase() %></span></div>
                                    <div class="fw-bold text-danger mt-1 fs-5"><%= dh.TongTien.toLocaleString('vi-VN') %>đ</div>
                                </div>
                                <div class="text-end">
                                    <% if(dh.TrangThai == 0) { %><span class="badge bg-warning text-dark rounded-pill">Chờ xác nhận</span>
                                    <% } else if(dh.TrangThai == 1) { %><span class="badge bg-info text-white rounded-pill">Đang giao</span>
                                    <% } else if(dh.TrangThai == 2) { %><span class="badge bg-success text-white rounded-pill">Đã nhận hàng</span>
                                    <% } else { %><span class="badge bg-secondary text-white rounded-pill">Đã hủy</span><% } %>
                                   <div class="mt-2 d-flex justify-content-end gap-2">
                                        <a href="/donhang/chitiet/<%= dh._id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3">Chi tiết</a>

                                        <% 
                                            let gioHienTai = new Date();
                                            let gioDatHang = new Date(dh.NgayLap); // Phải đảm bảo DB ông có cột NgayLap nhé
                                            let phutTroiQua = Math.floor((gioHienTai - gioDatHang) / (1000 * 60));
                                        %>

                                        <% if(dh.TrangThai == 0) { %> <% if(phutTroiQua <= 30) { %>
                                                <a href="/donhang/huy/<%= dh._id %>" 
                                                class="btn btn-sm btn-danger rounded-pill px-3" 
                                                onclick="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không?');">
                                                Hủy đơn
                                                </a>
                                            <% } else { %>
                                                <button class="btn btn-sm btn-secondary rounded-pill px-3 disabled" 
                                                        style="opacity: 0.6; cursor: not-allowed;"
                                                        title="Đã quá thời gian cho phép hủy">
                                                    Hủy đơn
                                                </button>
                                            <% } %>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
        <%- include('footer') %>
    </div>
    <%- include('javascript') %>
</body>
</html>