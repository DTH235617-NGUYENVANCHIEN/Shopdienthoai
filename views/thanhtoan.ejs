<!DOCTYPE html>
<html lang="vi">
<head>
   <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
    <style>
        body { background-color: #f4f6f9; }
        .card-custom { border-radius: 15px; border: none; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
    </style>
</head>
<body>
    <%- include('navbar') %>

    <div class="container py-5">
        <h3 class="fw-bold mb-4"><i class="bi bi-wallet2 text-primary me-2"></i>Tiến hành thanh toán</h3>
        
        <form action="/donhang/xacnhan" method="POST">
            <div class="row">
                <div class="col-md-7 mb-4">
                    <div class="card card-custom p-4 h-100">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">Thông tin giao hàng</h5>
                        
                        <div class="mb-3">
                            <label class="form-label text-muted fw-bold small">Họ và tên người nhận</label>
                            <input type="text" class="form-control" name="HoTenNhan" value="<%= HoVaTen %>" required placeholder="Nhập tên người nhận">
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label text-muted fw-bold small">Số điện thoại liên hệ</label>
                            <input type="text" class="form-control" name="DienThoaiNhan" required placeholder="Ví dụ: 0987654321" pattern="[0-9]{10}">
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label text-muted fw-bold small">Địa chỉ nhận hàng chi tiết</label>
                            <textarea class="form-control" name="DiaChiNhan" rows="3" required placeholder="Số nhà, Tên đường, Phường/Xã, Quận/Huyện..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted fw-bold small">Ghi chú cho shipper (Tùy chọn)</label>
                            <input type="text" class="form-control" name="GhiChu" placeholder="Ví dụ: Giao giờ hành chính">
                        </div>
                        <h5 class="fw-bold mb-3 border-bottom pb-2 mt-4">Phương thức thanh toán</h5>
                        
                        <div class="card border border-primary mb-2 shadow-sm">
                            <div class="card-body py-2">
                                <div class="form-check">
                                    <input class="form-check-input fs-5" type="radio" name="PhuongThucThanhToan" id="cod" value="COD" checked>
                                    <label class="form-check-label ms-2 mt-1 fw-bold text-dark" for="cod">
                                        💵 Thanh toán khi nhận hàng (COD)
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="card border mb-2">
                            <div class="card-body py-2">
                                <div class="form-check">
                                    <input class="form-check-input fs-5" type="radio" name="PhuongThucThanhToan" id="bank" value="Chuyển khoản">
                                    <label class="form-check-label ms-2 mt-1 fw-bold text-dark" for="bank">
                                        🏦 Chuyển khoản ngân hàng (Quét mã QR)
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="card border mb-2">
                            <div class="card-body py-2">
                                <div class="form-check">
                                    <input class="form-check-input fs-5" type="radio" name="PhuongThucThanhToan" id="momo" value="MoMo">
                                    <label class="form-check-label ms-2 mt-1 fw-bold text-dark" for="momo">
                                        🟣 Thanh toán qua Ví MoMo
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-5 mb-4">
                    <div class="card card-custom p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">Tóm tắt đơn hàng</h5>
                        
                        <div class="order-items mb-3" style="max-height: 300px; overflow-y: auto;">
                            <% giohang.forEach(sp => { %>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div>
                                        <h6 class="mb-0 fw-bold"><%= sp.TenSP %></h6>
                                        <small class="text-muted">SL: <%= sp.SoLuong %> x <%= sp.DonGia.toLocaleString('vi-VN') %>đ</small>
                                    </div>
                                    <span class="fw-bold text-danger"><%= sp.ThanhTien.toLocaleString('vi-VN') %>đ</span>
                                </div>
                            <% }) %>
                        </div>

                        <div class="border-top pt-3 mt-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tạm tính:</span>
                                <span class="fw-bold"><%= tongTien.toLocaleString('vi-VN') %>đ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span class="text-muted">Phí giao hàng:</span>
                                <span class="text-success fw-bold">Miễn phí</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded">
                                <span class="fw-bold fs-5">TỔNG CỘNG:</span>
                                <span class="fw-bold fs-4 text-danger"><%= tongTien.toLocaleString('vi-VN') %>đ</span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 mt-4 fw-bold fs-5 rounded-3 shadow">
                            CHỐT ĐƠN NGAY <i class="bi bi-cart-check ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <%- include('javascript') %>
</body>
</html>