<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .main-card { border: none; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); }
        .table thead th { background-color: #f8f9fa; border-bottom: none; color: #333; font-weight: 600; padding: 15px; }
        .btn-pill { border-radius: 50px; padding: 8px 20px; font-weight: 600; }
        /* Style cho nhãn trạng thái */
        .badge-status { border-radius: 8px; padding: 6px 12px; font-weight: 600; text-decoration: none; display: inline-block; }
        .product-name-link {
        transition: color 0.2s ease-in-out;
        }
        
        .product-name-link:hover {
            color: #0d6efd !important; /* Đổi sang màu xanh khi rà chuột vào */
            text-decoration: underline !important; /* Gạch chân cho giống link chuyên nghiệp */
        }
    </style>
</head>
<body>
    <%- include('navbar') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold m-0"><i class="bi bi-phone-fill text-warning me-2"></i>Quản Lý Sản Phẩm</h3>
            <div>
                <a href="/dienthoai/them" class="btn btn-primary btn-pill shadow-sm">
                    <i class="bi bi-plus-lg me-1"></i> Thêm Sản Phẩm
                </a>
                <a href="/admin" class="btn btn-light btn-pill border ms-2">Quay lại</a>
            </div>
        </div>

        <div class="card main-card overflow-hidden">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0 text-center">
                    <thead>
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Ảnh</th>
                            <th class="text-start">Tên sản phẩm</th>
                            <th>Thương hiệu</th>
                            <th>Giá bán</th>
                            <th>Số lượng</th>
                            <th>Trạng thái</th>
                            <th class="pe-4">Thiết lập</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% var stt = 1; %>
                        <% dienthoai.forEach(dt => { %>
                            <tr>
                                <td class="ps-4"><%= stt++ %></td>
                                <td>
                                    <img src="<%= dt.HinhAnh %>" class="rounded border" style="width: 45px; height: 45px; object-fit: contain; background: #fff;">
                                </td>
                                
                                <td class="text-start fw-bold">
                                    <a href="/dienthoai/chitiet/<%= dt._id %>" class="text-decoration-none text-dark product-name-link">
                                        <%= dt.TenSP %>
                                    </a>
                                </td>
                                <td><span class="badge bg-secondary opacity-75"><%= dt.ThuongHieu ? dt.ThuongHieu.TenThuongHieu : 'N/A' %></span></td>
                                <td class="text-primary fw-bold"><%= dt.DonGia.toLocaleString('vi-VN') %>đ</td>
                                <td>
                                    <strong><%= dt.SoLuong %></strong>
                                        <% if(dt.SoLuong < 5) { %>
                                            <br><span class="badge bg-warning text-dark">Cần nhập thêm!</span>
                                        <% } %>
                                </td>
                                <td>
                                    <% if(dt.TrangThai == 1) { %>
                                        <a href="/dienthoai/doitrangthai/<%= dt._id %>" class="badge-status bg-success-subtle text-success border border-success">
                                            <i class="bi bi-check-circle-fill me-1"></i> Đang bán
                                        </a>
                                    <% } else { %>
                                        <a href="/dienthoai/doitrangthai/<%= dt._id %>" class="badge-status bg-danger-subtle text-danger border border-danger">
                                            <i class="bi bi-x-circle-fill me-1"></i> Ngừng kinh doanh
                                        </a>
                                    <% } %>
                                </td>

                                <td class="pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="/dienthoai/sua/<%= dt._id %>" class="btn btn-outline-primary btn-sm px-3 rounded-pill shadow-sm">
                                            <i class="bi bi-pencil me-1"></i> Sửa
                                        </a>
                                        <a href="/dienthoai/xoa/<%= dt._id %>" class="btn btn-outline-danger btn-sm px-2 rounded-pill shadow-sm" onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này không?')">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
       
    </div>
     <%- include('footer') %>
    <%- include('javascript') %>
</body>
</html>