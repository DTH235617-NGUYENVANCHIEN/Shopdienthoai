<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }
        .form-card { border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); margin-top: 30px; }
        .card-header { background: #fff; border-bottom: 1px solid #eee; border-radius: 20px 20px 0 0 !important; padding: 1.5rem 2rem; }
    </style>
</head>
<body>
    <%- include('navbar') %>

    <div class="container py-4 mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="card form-card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold m-0 text-primary"><i class="bi bi-person-gear me-2"></i><%= title %></h5>
                        <a href="/taikhoan" class="btn btn-light btn-sm rounded-pill border">Hủy & Quay lại</a>
                    </div>
                    
                    <div class="card-body p-4">
                        <% if (typeof session !== 'undefined' && session.error) { %>
                            <div class="alert alert-danger"><%- session.error %></div>
                            <% delete session.error; %>
                        <% } %>

                        <div class="text-center mb-4">
                            <% if(taikhoan.HinhAnh) { %>
                                <img src="<%= taikhoan.HinhAnh %>" class="rounded-circle shadow-sm" style="width: 100px; height: 100px; object-fit: cover; border: 3px solid #fff;">
                            <% } else { %>
                                <i class="bi bi-person-circle text-muted" style="font-size: 5rem;"></i>
                            <% } %>
                            <h5 class="mt-2 fw-bold"><%= taikhoan.TenDangNhap %></h5>
                        </div>

                        <form action="/taikhoan/sua/<%= taikhoan._id %>" method="post" enctype="multipart/form-data">
                            
                            <input type="hidden" name="HinhAnh" value="<%= taikhoan.HinhAnh %>" />

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Họ và tên <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="HoVaTen" value="<%= taikhoan.HoVaTen %>" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Email</label>
                                <input type="email" class="form-control" name="Email" value="<%= taikhoan.Email %>" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Cập nhật hình đại diện mới</label>
                                <input type="file" class="form-control" name="HinhAnh" accept="image/*" />
                                <div class="form-text small">Bỏ trống nếu không muốn đổi ảnh.</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Tên đăng nhập <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="TenDangNhap" value="<%= taikhoan.TenDangNhap %>" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Cấp lại mật khẩu mới</label>
                                <input type="password" class="form-control" name="MatKhau" placeholder="Để trống nếu không muốn đổi mật khẩu..." />
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-6">
                                    <label class="form-label fw-bold small text-muted">Quyền hạn</label>
                                    <select class="form-select" name="QuyenHan">
                                        <option value="0" <%= taikhoan.QuyenHan == 0 ? 'selected' : '' %>>Khách hàng</option>
                                        <option value="1" <%= taikhoan.QuyenHan == 1 ? 'selected' : '' %>>Quản trị viên (Admin)</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-bold small text-muted">Trạng thái</label>
                                    <select class="form-select" name="KichHoat">
                                        <option value="1" <%= taikhoan.KichHoat == 1 ? 'selected' : '' %>>Đang hoạt động</option>
                                        <option value="0" <%= taikhoan.KichHoat == 0 ? 'selected' : '' %>>Khóa tài khoản</option>
                                    </select>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm text-uppercase">LƯU CẬP NHẬT</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <%- include('javascript') %>
</body>
</html>