<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }
        .main-card { border: none; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); }
        .badge-status { border-radius: 8px; padding: 6px 12px; font-weight: 600; font-size: 0.8rem; }
    </style>
</head>
<body>
    <%- include('navbar') %>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold m-0"><i class="bi bi-shield-check text-primary me-2"></i>Quản Lý Đơn Hàng</h3>
            <a href="/admin" class="btn btn-light border rounded-pill px-4 fw-bold shadow-sm text-decoration-none">Quay lại</a>
        </div>

        <div class="card main-card overflow-hidden bg-white">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0 text-center text-nowrap">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" width="10%">#</th>
                            <th class="ps-4">Ngày lập</th>
                            <th class="text-start">Người nhận</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="pe-4">Thiết lập</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% var stt = 1; %>
                        <% donhang.forEach(dh => { %>
                            <tr>
                                <td class="ps-4"><%= stt++ %></td>
                                <td class="ps-4 small text-muted"><%= new Date(dh.NgayLap).toLocaleString('vi-VN') %></td>
                                <td class="text-start">
                                    <div class="fw-bold text-dark"><%= dh.NguoiNhan %></div>
                                    <div class="small text-muted"><%= dh.SDT %></div>
                                </td>
                                <td class="text-primary fw-bold"><%= dh.TongTien.toLocaleString('vi-VN') %>đ</td>
                                <td>
                                    <% if(dh.TrangThai == 0) { %>
                                        <span class="badge-status bg-warning-subtle text-warning border border-warning">Chờ xác nhận</span>
                                    <% } else if(dh.TrangThai == 1) { %>
                                        <span class="badge-status bg-info-subtle text-info border border-info">Đang giao</span>
                                    <% } else if(dh.TrangThai == 2) { %>
                                        <span class="badge-status bg-success-subtle text-success border border-success">Đã giao</span>
                                    <% } else { %>
                                        <span class="badge-status bg-danger-subtle text-danger border border-danger">Đã hủy</span>
                                    <% } %>
                                </td>
                                <td class="pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="/donhang/chitiet/<%= dh._id %>" class="btn btn-outline-secondary btn-sm rounded-pill px-3" title="Xem chi tiết"><i class="bi bi-eye"></i></a>
                                        
                                        <% if(dh.TrangThai < 2) { %>
                                            <a href="/donhang/duyet/<%= dh._id %>" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                                <i class="bi bi-check-lg"></i> Duyệt đơn
                                            </a>
                                        <% } %>
                                        
                                        <a href="/donhang/xoa/<%= dh._id %>" class="btn btn-outline-danger btn-sm rounded-pill px-2" onclick="return confirm('Hủy đơn hàng này?')"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
      
    </div>
     <%- include('footer') %>
    <%- include('javascript') %>
</body>
</html>