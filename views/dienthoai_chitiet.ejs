<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
</head>
<body class="bg-light">
    
        <%- include('navbar') %>
    <div class="container">   
        <div class="card border-0 shadow-sm mt-4 p-4 rounded-4 bg-white">
            <div class="mb-3">
                <a href="/" class="text-decoration-none text-secondary fw-bold">
                    <i class="bi bi-chevron-left"></i> Quay lại trang chủ
                </a>
            </div>
            <div class="row g-4 align-items-center">
                <div class="col-md-5 text-center p-3">
                    <img src="<%= dt.HinhAnh %>" class="img-fluid rounded-4 shadow-sm p-3 bg-white border" style="max-height: 450px;">
                </div>
                <div class="col-md-7">
                    <h2 class="fw-bold text-dark mb-1"><%= dt.TenSP %></h2>
                    <div class="badge bg-dark text-warning mb-4 px-3 py-2 rounded-pill shadow-sm">
                        <i class="bi bi-tag-fill me-2"></i><%= dt.ThuongHieu ? dt.ThuongHieu.TenThuongHieu : 'Hãng khác' %>
                    </div>
                    <h3 class="text-danger fw-bold mb-4"><%= dt.DonGia.toLocaleString('vi-VN') %> VNĐ</h3>
                    
                    <div class="card border-0 bg-light rounded-4 mb-4 shadow-sm">
                        <div class="card-body p-3 small">
                            <h6 class="fw-bold text-dark border-bottom pb-2 mb-3"><i class="bi bi-cpu-fill me-2"></i>THÔNG SỐ KỸ THUẬT</h6>
                            <div class="row mb-2"><div class="col-4 text-muted">Màn hình:</div><div class="col-8 fw-bold"><%= dt.ManHinh %></div></div>
                            <div class="row mb-2"><div class="col-4 text-muted">Vi xử lý:</div><div class="col-8 fw-bold text-primary"><%= dt.CPU %></div></div>
                            <div class="row mb-2"><div class="col-4 text-muted">RAM/ROM:</div><div class="col-8 fw-bold"><%= dt.Ram %> / <%= dt.Rom %></div></div>
                            <div class="row mb-0"><div class="col-4 text-muted">Dung lượng Pin:</div><div class="col-8 fw-bold"><%= dt.Pin %></div></div>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <% if(typeof session !== 'undefined' && session.QuyenHan == 1) { %>
                            <a href="/dienthoai/sua/<%= dt._id %>" class="btn btn-primary btn-lg fw-bold rounded-pill shadow-sm py-3">
                                <i class="bi bi-pencil-square me-2"></i> CHỈNH SỬA THÔNG TIN
                            </a>
                            <a href="/dienthoai" class="btn btn-outline-secondary rounded-pill fw-bold">
                                <i class="bi bi-arrow-left me-2"></i> Quay lại trang quản lý
                            </a>
                        <% } else { %>
                            <a href="/donhang/them/<%= dt._id %>" class="btn btn-warning btn-lg fw-bold rounded-pill shadow-sm py-3">
                                <i class="bi bi-bag-plus-fill me-2"></i> CHO VÀO GIỎ HÀNG
                            </a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
        <%- include('footer') %>
    </div>
    <%- include('javascript') %>
</body>
</html>