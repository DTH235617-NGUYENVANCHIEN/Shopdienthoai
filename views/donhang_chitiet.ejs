    <!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %></title>
</head>
<body class="bg-light">
    <%- include('navbar') %>
    <div class="container mt-4 mb-5">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
            <h4 class="fw-bold border-bottom pb-3 mb-4 text-primary">CHI TIẾT ĐƠN HÀNG</h4>
            
            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <h6 class="fw-bold text-secondary">THÔNG TIN NHẬN HÀNG</h6>
                    <p class="mb-1"><strong>Người nhận:</strong> <%= donhang.NguoiNhan %></p>
                    <p class="mb-1"><strong>Điện thoại:</strong> <%= donhang.SDT %></p>
                    <p class="mb-1"><strong>Địa chỉ:</strong> <%= donhang.DiaChi %></p>
                    <p class="mb-0"><strong>Ghi chú:</strong> <span class="text-muted italic"><%= donhang.GhiChu || 'Không có' %></span></p>
                </div>
                <div class="col-md-6 text-md-end">
                    <h6 class="fw-bold text-secondary">THANH TOÁN</h6>
                    <p class="mb-1"><strong>Phương thức:</strong> <%= donhang.PhuongThucTT %></p>
                    <h4 class="fw-bold text-danger mt-2"><%= donhang.TongTien.toLocaleString('vi-VN') %>đ</h4>
                </div>
            </div>

            <table class="table table-bordered table-sm align-middle text-center small">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Sản phẩm</th>
                        <th>Giá</th>
                        <th>SL</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    <% var stt = 1; %>
                    <% chitietdonhang.forEach(ct => { %>
                        <tr>
                            <td><%= stt++ %></td>
                            <td class="text-start ps-3 fw-bold"><%= ct.DienThoai ? ct.DienThoai.TenSP : 'Sản phẩm không còn tồn tại' %></td>
                            <td><%= ct.DonGia.toLocaleString('vi-VN') %>đ</td>
                            <td><%= ct.SoLuong %></td>
                            <td class="fw-bold"><%= (ct.DonGia * ct.SoLuong).toLocaleString('vi-VN') %>đ</td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
            
            <div class="mt-4">
                <button onclick="window.history.back()" class="btn btn-light rounded-pill border px-4">Quay lại</button>
            </div>
        </div>
        <%- include('footer') %>
    </div>
    <%- include('javascript') %>
</body>
</html>